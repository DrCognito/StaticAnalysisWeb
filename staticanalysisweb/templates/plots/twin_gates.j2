{% extends "team.j2" %}
{% block vis %}
{% if plots["twin_gate_transitions"] is not none %}
<h2>Twin Gate Usage</h2>
    <img src={{plots["twin_gate_transitions"]}}>
{% endif %}
{% if plots.global_twin_gate_transitions is defined %}
<h3>Global</h3>
